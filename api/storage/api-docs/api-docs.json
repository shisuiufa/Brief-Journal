                "security": [
                    {
                        "sanctumBearer": []
                    },
                    {
                        "sanctumCookie": [],
                        "xsrfToken": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "UserResource": {
                "required": [
                    "id",
                    "name",
                    "email",
                    "roles"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "jane@example.com"
                    },
                    "roles": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "example": "editor"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctumBearer": {
                "type": "http",
                "description": "Use a Laravel Sanctum personal access token in the Authorization header.",
                "scheme": "bearer",
                "bearerFormat": "Token"
            },
            "sanctumCookie": {
                "type": "apiKey",
                "description": "Laravel Sanctum SPA session cookie.",
                "name": "laravel_session",
                "in": "cookie"
            },
            "xsrfToken": {
                "type": "apiKey",
                "description": "CSRF token header required for stateful Sanctum SPA requests.",
                "name": "X-XSRF-TOKEN",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Admin Users",
            "description": "Administrative user management endpoints"
        },
        {
            "name": "Authentication",
            "description": "Authentication and Laravel Sanctum session endpoints"
        }
    ]
